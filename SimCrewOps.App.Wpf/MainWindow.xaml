<Window x:Class="SimCrewOps.App.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:model="clr-namespace:SimCrewOps.App.Wpf.Models"
        xmlns:local="clr-namespace:SimCrewOps.App.Wpf.Views"
        xmlns:vm="clr-namespace:SimCrewOps.App.Wpf.ViewModels"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="SimCrewOps Tracker"
        Width="1440"
        Height="960"
        MinWidth="1200"
        MinHeight="800"
        Background="{StaticResource ShellBackgroundBrush}">

    <Window.Resources>
        <!-- Section label used inside content panels -->
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize"   Value="11" />
            <Setter Property="FontWeight" Value="SemiBold" />
        </Style>

        <!-- Dark card border -->
        <Style x:Key="DarkCardStyle" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource PanelBrush}" />
            <Setter Property="BorderBrush"     Value="{StaticResource DividerBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius"    Value="8" />
            <Setter Property="Padding"         Value="16" />
        </Style>

        <!-- ── Metric list row (used in Review left panel) ───────────── -->
        <Style x:Key="MetricListRowStyle" TargetType="Grid">
            <Setter Property="Margin" Value="0" />
            <Setter Property="Height" Value="40" />
        </Style>
        <Style x:Key="MetricListLabelStyle" TargetType="TextBlock">
            <Setter Property="FontSize"       Value="13" />
            <Setter Property="Foreground"     Value="{StaticResource TextMutedBrush}" />
            <Setter Property="VerticalAlignment" Value="Center" />
            <Setter Property="Margin"         Value="14,0,0,0" />
        </Style>
        <Style x:Key="MetricListDividerStyle" TargetType="Border">
            <Setter Property="Height"          Value="1" />
            <Setter Property="Background"      Value="{StaticResource BorderSubtleBrush}" />
            <Setter Property="HorizontalAlignment" Value="Stretch" />
        </Style>
    </Window.Resources>

    <!-- ══ Root: sidebar | content ══════════════════════════════════════ -->
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="240" />
            <ColumnDefinition Width="*" />
        </Grid.ColumnDefinitions>

        <!-- ══ SIDEBAR ═══════════════════════════════════════════════════ -->
        <Grid Grid.Column="0" Background="{StaticResource SidebarBrush}">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto" />  <!-- logo -->
                <RowDefinition Height="*"    />  <!-- nav items -->
                <RowDefinition Height="Auto" />  <!-- bottom status -->
            </Grid.RowDefinitions>

            <!-- Logo header -->
            <StackPanel Grid.Row="0" Margin="20,20,20,28">
                <TextBlock Text="SIMCREWOPS"
                           Foreground="#c9d1d9"
                           FontSize="13"
                           FontWeight="Bold" />
                <TextBlock Text="TrackerV2"
                           Foreground="{StaticResource TextSubtleBrush}"
                           FontSize="11"
                           Margin="0,3,0,0" />
            </StackPanel>

            <!-- Nav items -->
            <StackPanel Grid.Row="1">

                <!-- FLIGHT OPS section -->
                <TextBlock Text="FLIGHT OPS"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" FontWeight="SemiBold"
                           Margin="20,0,0,6" />

                <!-- Dispatch -->
                <Button Command="{Binding ShowDashboardCommand}" Style="{StaticResource NavButtonStyle}" Margin="8,1">
                    <Border Padding="12,9" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDashboardVisible}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource NavActiveBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◈" FontSize="13" Margin="0,0,9,0" VerticalAlignment="Center">
                                <TextBlock.Style><Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#7d8590"/>
                                    <Style.Triggers><DataTrigger Binding="{Binding IsDashboardVisible}" Value="True"><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers>
                                </Style></TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="Dispatch" FontSize="13">
                                <TextBlock.Style><Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#c9d1d9"/>
                                    <Style.Triggers><DataTrigger Binding="{Binding IsDashboardVisible}" Value="True"><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers>
                                </Style></TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Button>

                <!-- Live Map -->
                <Button Command="{Binding ShowLiveMapCommand}" Style="{StaticResource NavButtonStyle}" Margin="8,1">
                    <Border Padding="12,9" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsLiveMapVisible}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource NavActiveBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="↗" FontSize="13" Margin="0,0,9,0" VerticalAlignment="Center">
                                <TextBlock.Style><Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#7d8590"/>
                                    <Style.Triggers><DataTrigger Binding="{Binding IsLiveMapVisible}" Value="True"><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers>
                                </Style></TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="Live Map" FontSize="13">
                                <TextBlock.Style><Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#c9d1d9"/>
                                    <Style.Triggers><DataTrigger Binding="{Binding IsLiveMapVisible}" Value="True"><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers>
                                </Style></TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Button>

                <!-- ACARS / Comms -->
                <Button Command="{Binding ShowAcarsCommand}" Style="{StaticResource NavButtonStyle}" Margin="8,1">
                    <Border Padding="12,9" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsAcarsVisible}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource NavActiveBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="✉" FontSize="13" Margin="0,0,9,0" VerticalAlignment="Center">
                                <TextBlock.Style><Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#7d8590"/>
                                    <Style.Triggers><DataTrigger Binding="{Binding IsAcarsVisible}" Value="True"><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers>
                                </Style></TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="ACARS / Comms" FontSize="13">
                                <TextBlock.Style><Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#c9d1d9"/>
                                    <Style.Triggers><DataTrigger Binding="{Binding IsAcarsVisible}" Value="True"><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers>
                                </Style></TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Button>

                <Border Height="1" Background="{StaticResource DividerBrush}" Margin="20,14,20,14" />

                <!-- SESSIONS section -->
                <TextBlock Text="SESSIONS"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" FontWeight="SemiBold"
                           Margin="20,0,0,6" />

                <!-- PIREP Draft -->
                <Button Command="{Binding ShowReviewCommand}" Style="{StaticResource NavButtonStyle}" Margin="8,1">
                    <Border Padding="12,9" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsReviewVisible}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource NavActiveBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="▤" FontSize="13" Margin="0,0,9,0" VerticalAlignment="Center">
                                <TextBlock.Style><Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#7d8590"/>
                                    <Style.Triggers><DataTrigger Binding="{Binding IsReviewVisible}" Value="True"><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers>
                                </Style></TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="PIREP Draft" FontSize="13">
                                <TextBlock.Style><Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#c9d1d9"/>
                                    <Style.Triggers><DataTrigger Binding="{Binding IsReviewVisible}" Value="True"><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers>
                                </Style></TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Button>

                <Border Height="1" Background="{StaticResource DividerBrush}" Margin="20,14,20,14" />

                <!-- SYSTEM section -->
                <TextBlock Text="SYSTEM"
                           Foreground="{StaticResource TextMutedBrush}"
                           FontSize="11" FontWeight="SemiBold"
                           Margin="20,0,0,6" />

                <!-- Diagnostics -->
                <Button Command="{Binding ShowDiagnosticsCommand}" Style="{StaticResource NavButtonStyle}" Margin="8,1">
                    <Border Padding="12,9" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsDiagnosticsVisible}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource NavActiveBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="◎" FontSize="13" Margin="0,0,9,0" VerticalAlignment="Center">
                                <TextBlock.Style><Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#7d8590"/>
                                    <Style.Triggers><DataTrigger Binding="{Binding IsDiagnosticsVisible}" Value="True"><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers>
                                </Style></TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="Diagnostics" FontSize="13">
                                <TextBlock.Style><Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#c9d1d9"/>
                                    <Style.Triggers><DataTrigger Binding="{Binding IsDiagnosticsVisible}" Value="True"><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers>
                                </Style></TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Button>

                <!-- Settings -->
                <Button Command="{Binding ShowSettingsCommand}" Style="{StaticResource NavButtonStyle}" Margin="8,1">
                    <Border Padding="12,9" CornerRadius="6">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background" Value="Transparent"/>
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding IsSettingsVisible}" Value="True">
                                        <Setter Property="Background" Value="{StaticResource NavActiveBrush}"/>
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="≡" FontSize="13" Margin="0,0,9,0" VerticalAlignment="Center">
                                <TextBlock.Style><Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#7d8590"/>
                                    <Style.Triggers><DataTrigger Binding="{Binding IsSettingsVisible}" Value="True"><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers>
                                </Style></TextBlock.Style>
                            </TextBlock>
                            <TextBlock Text="Settings" FontSize="13">
                                <TextBlock.Style><Style TargetType="TextBlock">
                                    <Setter Property="Foreground" Value="#c9d1d9"/>
                                    <Style.Triggers><DataTrigger Binding="{Binding IsSettingsVisible}" Value="True"><Setter Property="Foreground" Value="White"/></DataTrigger></Style.Triggers>
                                </Style></TextBlock.Style>
                            </TextBlock>
                        </StackPanel>
                    </Border>
                </Button>

            </StackPanel>

            <!-- Bottom: status badges -->
            <StackPanel Grid.Row="2" Margin="20,0,20,20">
                <Border Height="1" Background="{StaticResource DividerBrush}" Margin="0,0,0,14" />

                <Border Background="{Binding MsfsStatusBrush}" CornerRadius="6" Padding="10,5" Margin="0,0,0,6">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="#C4F5EE" Margin="0,1,7,0" VerticalAlignment="Center" />
                        <TextBlock Text="{Binding MsfsStatusText}" Foreground="#EEF9F8" FontSize="11" FontWeight="Bold" />
                    </StackPanel>
                </Border>

                <Border Background="{Binding SyncStatusBrush}" CornerRadius="6" Padding="10,5" Margin="0,0,0,6">
                    <TextBlock Text="{Binding SyncStatusText}" Foreground="#EEF2F4" FontSize="11" FontWeight="Bold" />
                </Border>

                <Border Background="{Binding LiveSyncStatusBrush}" CornerRadius="6" Padding="10,5">
                    <TextBlock Text="{Binding LiveSyncStatusText}" Foreground="White" FontSize="11" FontWeight="Bold" />
                </Border>

                <!-- App version -->
                <TextBlock Text="{x:Static vm:MainWindowViewModel.AppVersion}"
                           Foreground="{StaticResource TextSubtleBrush}"
                           FontSize="10"
                           FontFamily="Consolas"
                           Margin="2,10,0,0" />
            </StackPanel>
        </Grid>

        <!-- Sidebar right border -->
        <Border Grid.Column="0" BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,1,0" />

        <!-- ══ MAIN CONTENT ═══════════════════════════════════════════════ -->
        <Grid Grid.Column="1">
            <Grid.RowDefinitions>
                <RowDefinition Height="56" />   <!-- top bar -->
                <RowDefinition Height="*"   />   <!-- content -->
            </Grid.RowDefinitions>

            <!-- Top bar -->
            <Border Grid.Row="0" Background="{StaticResource TopBarBrush}"
                    BorderBrush="{StaticResource DividerBrush}" BorderThickness="0,0,0,1">
                <Grid Margin="24,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="Auto" />
                    </Grid.ColumnDefinitions>

                    <!-- Flight context + web-fetched assignment -->
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding HeaderFlightText}"
                                   Foreground="#8b949e"
                                   FontSize="13" />
                        <TextBlock FontSize="11"
                                   Margin="0,3,0,0">
                            <TextBlock.Style>
                                <Style TargetType="TextBlock">
                                    <Setter Property="Visibility" Value="Collapsed" />
                                    <Style.Triggers>
                                        <DataTrigger Binding="{Binding AssignedFlightText, Converter={StaticResource StringNotEmptyConverter}}" Value="True">
                                            <Setter Property="Visibility" Value="Visible" />
                                        </DataTrigger>
                                    </Style.Triggers>
                                </Style>
                            </TextBlock.Style>
                            <Run Text="ASSIGNED  " Foreground="{StaticResource TextSubtleBrush}" FontWeight="SemiBold" />
                            <Run Text="{Binding AssignedFlightText}" Foreground="{StaticResource AccentSoftBrush}" />
                        </TextBlock>
                    </StackPanel>

                    <!-- Phase pill + career chips -->
                    <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Background="#1c2333" CornerRadius="6" Padding="10,4" Margin="0,0,8,0">
                            <TextBlock Text="{Binding CareerTier}" Foreground="#8b949e" FontSize="11" FontWeight="SemiBold" />
                        </Border>
                        <Border Background="#1c2333" CornerRadius="6" Padding="10,4" Margin="0,0,8,0">
                            <TextBlock Text="{Binding BidDisplay}" Foreground="#8b949e" FontSize="11" FontWeight="SemiBold" />
                        </Border>
                        <Border Background="{StaticResource AmberBrush}" CornerRadius="6" Padding="14,5">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="PHASE  " Foreground="#0d1117" FontSize="11" FontWeight="Bold" />
                                <TextBlock Text="{Binding PhaseTitle}" Foreground="#0d1117" FontSize="13" FontWeight="Bold" />
                            </StackPanel>
                        </Border>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ══ Content area ══════════════════════════════════════════ -->
            <Grid Grid.Row="1" Margin="16">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="240" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="16" />
                    <ColumnDefinition Width="260" />
                </Grid.ColumnDefinitions>

                <!-- ── Left panel: always-visible flight stack ─────────── -->
                <Border Grid.Column="0" Style="{StaticResource DarkCardStyle}" Padding="18">
                    <ScrollViewer VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled">
                        <StackPanel>
                            <TextBlock Text="Flight Stack"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       FontSize="16"
                                       FontWeight="SemiBold" />

                            <TextBlock Text="SESSION" Margin="0,22,0,8" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="{Binding CareerTier}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="20" FontWeight="Bold" />
                            <TextBlock Text="{Binding BidDisplay}" Foreground="{StaticResource TextMutedBrush}" Margin="0,6,0,0" FontSize="13" />
                            <TextBlock Text="{Binding ReputationDisplay}" Foreground="{StaticResource TextMutedBrush}" Margin="0,4,0,0" FontSize="13" />

                            <Border Height="1" Background="{StaticResource DividerBrush}" Margin="0,18,0,18" />

                            <TextBlock Text="FLIGHT TIMES" Style="{StaticResource SectionLabelStyle}" />
                            <Grid Margin="0,12,0,0">
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="OUT" Foreground="{StaticResource NavTextBrush}" FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Grid.Column="1" Text="{Binding OutTime}" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas" FontSize="14" />
                                <TextBlock Grid.Row="1" Text="OFF" Margin="0,10,0,0" Foreground="{StaticResource NavTextBrush}" FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="1" Grid.Column="1" Margin="0,10,0,0" Text="{Binding OffTime}" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas" FontSize="14" />
                                <TextBlock Grid.Row="2" Text="ON"  Margin="0,10,0,0" Foreground="{StaticResource NavTextBrush}" FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="2" Grid.Column="1" Margin="0,10,0,0" Text="{Binding OnTime}" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas" FontSize="14" />
                                <TextBlock Grid.Row="3" Text="IN"  Margin="0,10,0,0" Foreground="{StaticResource NavTextBrush}" FontSize="13" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="3" Grid.Column="1" Margin="0,10,0,0" Text="{Binding InTime}" Foreground="{StaticResource TextPrimaryBrush}" FontFamily="Consolas" FontSize="14" />
                            </Grid>

                            <Border Height="1" Background="{StaticResource DividerBrush}" Margin="0,18,0,18" />

                            <TextBlock Text="PHASE RAIL" Style="{StaticResource SectionLabelStyle}" />
                            <ItemsControl ItemsSource="{Binding PhasePills}" Margin="0,12,0,0">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <WrapPanel ItemWidth="62" ItemHeight="32" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type model:PhasePillModel}">
                                        <Border Width="54" Height="26" Margin="0,0,6,8" CornerRadius="5">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="#21262d" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource AmberBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                            <TextBlock Text="{Binding Label}"
                                                       VerticalAlignment="Center"
                                                       HorizontalAlignment="Center"
                                                       FontSize="10"
                                                       FontWeight="SemiBold">
                                                <TextBlock.Style>
                                                    <Style TargetType="TextBlock">
                                                        <Setter Property="Foreground" Value="#7d8590"/>
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                                <Setter Property="Foreground" Value="#0d1117"/>
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </TextBlock.Style>
                                            </TextBlock>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </ScrollViewer>
                </Border>

                <!-- ── Center + right: switching pages ─────────────────── -->
                <Grid Grid.Column="2" Grid.ColumnSpan="3">

                    <!-- ── DASHBOARD ───────────────────────────────────── -->
                    <Grid Visibility="{Binding IsDashboardVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*" />
                            <ColumnDefinition Width="16" />
                            <ColumnDefinition Width="260" />
                        </Grid.ColumnDefinitions>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="*" />
                            <RowDefinition Height="16" />
                            <RowDefinition Height="170" />
                        </Grid.RowDefinitions>

                        <!-- Live Ops Board (instruments) -->
                        <Border Grid.Column="0" Grid.Row="0"
                                Background="{StaticResource InstrumentPanelBrush}"
                                BorderBrush="#2E4C59" BorderThickness="1"
                                CornerRadius="8" Padding="22">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                    <RowDefinition Height="Auto" />
                                </Grid.RowDefinitions>

                                <TextBlock Text="LIVE OPS BOARD" Foreground="#9CC7CF" FontSize="11" FontWeight="SemiBold" />
                                <TextBlock Grid.Row="1" Text="{Binding PhaseTitle}" Foreground="#F1F6F4" FontSize="28" FontWeight="Bold" Margin="0,10,0,0" />
                                <TextBlock Grid.Row="2" Text="{Binding PhaseSubtitle}" Foreground="#83A4AE" FontSize="14" Margin="0,8,0,0" TextWrapping="Wrap" />
                                <TextBlock Grid.Row="2" Text="{Binding PhaseStatusLine}" Foreground="#83A4AE" FontSize="13" Margin="0,28,0,0" TextWrapping="Wrap" />

                                <!-- Instruments -->
                                <Border Grid.Row="3" Margin="0,14,0,0"
                                        Background="#0C1D25"
                                        BorderBrush="#2E4C59" BorderThickness="1"
                                        CornerRadius="8">
                                    <StackPanel Margin="18,14,18,12">
                                        <TextBlock Text="INSTRUMENTS" Foreground="#8FB3BE" FontSize="11" FontWeight="SemiBold" />

                                        <UniformGrid Columns="4" Margin="0,10,0,0">
                                            <Border Margin="0,0,6,0" Background="{StaticResource InstrumentTileBrush}" CornerRadius="6" Padding="10,7">
                                                <StackPanel>
                                                    <TextBlock Text="IAS  kt" Foreground="#7EA4AF" FontSize="10" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding LiveIas}" Foreground="#F0F6F3" FontSize="20" FontWeight="Bold" FontFamily="Consolas" />
                                                </StackPanel>
                                            </Border>
                                            <Border Margin="3,0,3,0" Background="{StaticResource InstrumentTileBrush}" CornerRadius="6" Padding="10,7">
                                                <StackPanel>
                                                    <TextBlock Text="GS  kt" Foreground="#7EA4AF" FontSize="10" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding LiveGs}" Foreground="#F0F6F3" FontSize="20" FontWeight="Bold" FontFamily="Consolas" />
                                                </StackPanel>
                                            </Border>
                                            <Border Margin="3,0,3,0" Background="{StaticResource InstrumentTileBrush}" CornerRadius="6" Padding="10,7">
                                                <StackPanel>
                                                    <TextBlock Text="MACH" Foreground="#7EA4AF" FontSize="10" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding LiveMach}" Foreground="#F0F6F3" FontSize="20" FontWeight="Bold" FontFamily="Consolas" />
                                                </StackPanel>
                                            </Border>
                                            <Border Margin="6,0,0,0" CornerRadius="6" Padding="10,7">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource InstrumentTileBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding LiveGForceAlert}" Value="True">
                                                                <Setter Property="Background" Value="#1E2E36" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                                                                <Setter Property="BorderThickness" Value="1" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock Text="G-FORCE" Foreground="#7EA4AF" FontSize="10" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding LiveGForce}" Foreground="#F0F6F3" FontSize="20" FontWeight="Bold" FontFamily="Consolas" />
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>

                                        <UniformGrid Columns="4" Margin="0,6,0,0">
                                            <Border Margin="0,0,6,0" Background="{StaticResource InstrumentTileBrush}" CornerRadius="6" Padding="10,7">
                                                <StackPanel>
                                                    <TextBlock Text="ALT  ft" Foreground="#7EA4AF" FontSize="10" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding LiveAlt}" Foreground="#F0F6F3" FontSize="20" FontWeight="Bold" FontFamily="Consolas" />
                                                </StackPanel>
                                            </Border>
                                            <Border Margin="3,0,3,0" CornerRadius="6" Padding="10,7">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource InstrumentTileBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding LiveAglAlert}" Value="True">
                                                                <Setter Property="Background" Value="#1E2E36" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                                                                <Setter Property="BorderThickness" Value="1" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock Text="AGL  ft" Foreground="#7EA4AF" FontSize="10" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding LiveAgl}" Foreground="#F0F6F3" FontSize="20" FontWeight="Bold" FontFamily="Consolas" />
                                                </StackPanel>
                                            </Border>
                                            <Border Margin="3,0,3,0" CornerRadius="6" Padding="10,7">
                                                <Border.Style>
                                                    <Style TargetType="Border">
                                                        <Setter Property="Background" Value="{StaticResource InstrumentTileBrush}" />
                                                        <Style.Triggers>
                                                            <DataTrigger Binding="{Binding LiveVsAlert}" Value="True">
                                                                <Setter Property="Background" Value="#1E2E36" />
                                                                <Setter Property="BorderBrush" Value="{StaticResource DangerBrush}" />
                                                                <Setter Property="BorderThickness" Value="1" />
                                                            </DataTrigger>
                                                        </Style.Triggers>
                                                    </Style>
                                                </Border.Style>
                                                <StackPanel>
                                                    <TextBlock Text="VS  fpm" Foreground="#7EA4AF" FontSize="10" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding LiveVs}" Foreground="#F0F6F3" FontSize="20" FontWeight="Bold" FontFamily="Consolas" />
                                                </StackPanel>
                                            </Border>
                                            <Border Margin="6,0,0,0" Background="{StaticResource InstrumentTileBrush}" CornerRadius="6" Padding="10,7">
                                                <StackPanel>
                                                    <TextBlock Text="HDG MAG" Foreground="#7EA4AF" FontSize="10" FontWeight="SemiBold" />
                                                    <TextBlock Text="{Binding LiveHdg}" Foreground="#F0F6F3" FontSize="20" FontWeight="Bold" FontFamily="Consolas" />
                                                </StackPanel>
                                            </Border>
                                        </UniformGrid>

                                        <!-- Systems LED strip -->
                                        <Border Margin="0,10,0,0" Background="#101D25" CornerRadius="6" Padding="12,8">
                                            <WrapPanel Orientation="Horizontal" VerticalAlignment="Center">
                                                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                                    <Ellipse Width="8" Height="8" Fill="{Binding LedBeaconBrush}" Margin="0,1,5,0" VerticalAlignment="Center" />
                                                    <TextBlock Text="BCN" Foreground="#8FB3BE" FontSize="11" FontWeight="SemiBold" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                                    <Ellipse Width="8" Height="8" Fill="{Binding LedStrobeBrush}" Margin="0,1,5,0" VerticalAlignment="Center" />
                                                    <TextBlock Text="STB" Foreground="#8FB3BE" FontSize="11" FontWeight="SemiBold" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                                    <Ellipse Width="8" Height="8" Fill="{Binding LedLandingBrush}" Margin="0,1,5,0" VerticalAlignment="Center" />
                                                    <TextBlock Text="LDG" Foreground="#8FB3BE" FontSize="11" FontWeight="SemiBold" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                                    <Ellipse Width="8" Height="8" Fill="{Binding LedTaxiBrush}" Margin="0,1,5,0" VerticalAlignment="Center" />
                                                    <TextBlock Text="TAXI" Foreground="#8FB3BE" FontSize="11" FontWeight="SemiBold" />
                                                </StackPanel>
                                                <Border Width="1" Height="11" Background="#2E4C59" Margin="0,1,20,0" />
                                                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                                    <Ellipse Width="8" Height="8" Fill="{Binding LedGearBrush}" Margin="0,1,5,0" VerticalAlignment="Center" />
                                                    <TextBlock Text="GEAR" Foreground="#8FB3BE" FontSize="11" FontWeight="SemiBold" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                                    <TextBlock Text="{Binding FlapsLabel}" Foreground="#8FB3BE" FontSize="11" FontWeight="SemiBold" />
                                                </StackPanel>
                                                <Border Width="1" Height="11" Background="#2E4C59" Margin="0,1,20,0" />
                                                <StackPanel Orientation="Horizontal" Margin="0,0,16,0">
                                                    <Ellipse Width="8" Height="8" Fill="{Binding LedEng1Brush}" Margin="0,1,5,0" VerticalAlignment="Center" />
                                                    <TextBlock Text="ENG1" Foreground="#8FB3BE" FontSize="11" FontWeight="SemiBold" />
                                                </StackPanel>
                                                <StackPanel Orientation="Horizontal" Margin="0,0,20,0">
                                                    <Ellipse Width="8" Height="8" Fill="{Binding LedEng2Brush}" Margin="0,1,5,0" VerticalAlignment="Center" />
                                                    <TextBlock Text="ENG2" Foreground="#8FB3BE" FontSize="11" FontWeight="SemiBold" />
                                                </StackPanel>
                                                <Border Width="1" Height="11" Background="#2E4C59" Margin="0,1,20,0" />
                                                <StackPanel Orientation="Horizontal">
                                                    <Ellipse Width="8" Height="8" Fill="{Binding LedParkingBrakeBrush}" Margin="0,1,5,0" VerticalAlignment="Center" />
                                                    <TextBlock Text="P-BRK" Foreground="#8FB3BE" FontSize="11" FontWeight="SemiBold" />
                                                </StackPanel>
                                            </WrapPanel>
                                        </Border>
                                    </StackPanel>
                                </Border>

                                <!-- Status chips -->
                                <ItemsControl Grid.Row="4" ItemsSource="{Binding StatusChips}" Margin="0,12,0,0">
                                    <ItemsControl.ItemsPanel>
                                        <ItemsPanelTemplate><WrapPanel /></ItemsPanelTemplate>
                                    </ItemsControl.ItemsPanel>
                                    <ItemsControl.ItemTemplate>
                                        <DataTemplate>
                                            <Border Background="#21262d" CornerRadius="5" Padding="12,5" Margin="0,0,8,0">
                                                <TextBlock Text="{Binding}" Foreground="#c9d1d9" FontSize="12" FontWeight="SemiBold" />
                                            </Border>
                                        </DataTemplate>
                                    </ItemsControl.ItemTemplate>
                                </ItemsControl>
                            </Grid>
                        </Border>

                        <!-- Scoreboard (bottom row) -->
                        <Border Grid.Row="2" Grid.Column="0"
                                Style="{StaticResource DarkCardStyle}" Padding="18">
                            <Grid>
                                <Grid.RowDefinitions>
                                    <RowDefinition Height="Auto" />
                                    <RowDefinition Height="*" />
                                </Grid.RowDefinitions>
                                <TextBlock Text="SCOREBOARD" Style="{StaticResource SectionLabelStyle}" />
                                <StackPanel Grid.Row="1" Orientation="Horizontal" Margin="0,10,0,0">
                                    <TextBlock Text="{Binding ScoreText}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="42" FontWeight="Bold" FontFamily="Consolas" />
                                    <TextBlock Text="{Binding GradeText}" Foreground="{StaticResource TextMutedBrush}" FontSize="22" FontWeight="Bold" Margin="12,10,0,0" />
                                </StackPanel>
                                <TextBlock Grid.Row="1" Text="{Binding ScoreSummary}" Margin="0,62,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="13" TextWrapping="Wrap" />
                            </Grid>
                        </Border>

                        <!-- Right column cards -->
                        <Grid Grid.Column="2" Grid.RowSpan="3">
                            <Grid.RowDefinitions>
                                <RowDefinition Height="*" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                                <RowDefinition Height="16" />
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- Approach check -->
                            <Border Background="#1c1a0f" BorderBrush="#a16207" BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="APPROACH CHECK" Foreground="#ca8a04" FontSize="11" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding AlertPrimaryTitle}" Margin="0,10,0,0" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding AlertPrimaryBody}" Margin="0,8,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="13" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <!-- Speed event -->
                            <Border Grid.Row="2" Background="{StaticResource DangerSoftBrush}" BorderBrush="{StaticResource DangerBrush}" BorderThickness="1" CornerRadius="8" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="SPEED EVENT" Foreground="{StaticResource DangerBrush}" FontSize="11" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding AlertSecondaryTitle}" Margin="0,10,0,0" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding AlertSecondaryBody}" Margin="0,8,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="13" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>

                            <!-- Dispatch -->
                            <Border Grid.Row="4" Style="{StaticResource DarkCardStyle}" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="DISPATCH" Foreground="{StaticResource AccentSoftBrush}" FontSize="11" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding DispatchTitle}" Margin="0,10,0,0" Foreground="{StaticResource TextPrimaryBrush}" FontSize="15" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding DispatchBody}" Margin="0,6,0,10" Foreground="{StaticResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap" />
                                    <Button Content="Open ACARS" Command="{Binding ShowAcarsCommand}" HorizontalAlignment="Left" Style="{StaticResource ShellActionButtonStyle}" />
                                </StackPanel>
                            </Border>

                            <!-- Session health -->
                            <Border Grid.Row="6" Style="{StaticResource DarkCardStyle}" Padding="16">
                                <StackPanel>
                                    <TextBlock Text="SESSION HEALTH" Style="{StaticResource SectionLabelStyle}" />
                                    <TextBlock Text="{Binding SessionHealthTitle}" Margin="0,10,0,0" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" />
                                    <TextBlock Text="{Binding SessionHealthLine1}" Margin="0,8,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                                    <TextBlock Text="{Binding SessionHealthLine2}" Margin="0,5,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="12" />
                                    <TextBlock Text="{Binding SessionHealthLine3}" Margin="0,5,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap" />
                                </StackPanel>
                            </Border>
                        </Grid>
                    </Grid>

                    <!-- ── ACARS / COMMS ────────────────────────────────── -->
                    <Border Visibility="{Binding IsAcarsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Style="{StaticResource DarkCardStyle}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <!-- Header bar -->
                                <RowDefinition Height="Auto" />
                                <!-- Message thread -->
                                <RowDefinition Height="*" />
                                <!-- Compose area -->
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <!-- Header bar -->
                            <Border Grid.Row="0"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderSubtleBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="20,13">
                                <Grid>
                                    <StackPanel Orientation="Horizontal">
                                        <TextBlock Text="✉" FontSize="14" Margin="0,0,10,0"
                                                   Foreground="{StaticResource AccentSoftBrush}"
                                                   VerticalAlignment="Center" />
                                        <TextBlock Text="ACARS / COMMS"
                                                   FontSize="13" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   VerticalAlignment="Center" />
                                    </StackPanel>
                                    <TextBlock Text="Live dispatch and in-flight messaging"
                                               FontSize="11"
                                               Foreground="{StaticResource TextSubtleBrush}"
                                               HorizontalAlignment="Right"
                                               VerticalAlignment="Center" />
                                </Grid>
                            </Border>

                            <!-- Message thread -->
                            <ScrollViewer Grid.Row="1"
                                          VerticalScrollBarVisibility="Auto"
                                          Padding="20,16">
                                <StackPanel>

                                    <!-- Empty-state placeholder (shown when no messages) -->
                                    <StackPanel HorizontalAlignment="Center" Margin="0,40,0,0">
                                        <StackPanel.Style>
                                            <Style TargetType="StackPanel">
                                                <Setter Property="Visibility" Value="Collapsed" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding AcarsMessages.Count}" Value="0">
                                                        <Setter Property="Visibility" Value="Visible" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </StackPanel.Style>
                                        <TextBlock Text="✉" FontSize="32" HorizontalAlignment="Center"
                                                   Foreground="{StaticResource TextSubtleBrush}" />
                                        <TextBlock Text="No messages yet"
                                                   FontSize="14" FontWeight="SemiBold"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   HorizontalAlignment="Center"
                                                   Margin="0,10,0,4" />
                                        <TextBlock Text="Dispatch and ACARS messages will appear here during your flight."
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSubtleBrush}"
                                                   HorizontalAlignment="Center"
                                                   TextAlignment="Center"
                                                   TextWrapping="Wrap"
                                                   MaxWidth="300" />
                                    </StackPanel>

                                    <!-- Message bubbles -->
                                    <ItemsControl ItemsSource="{Binding AcarsMessages}">
                                        <ItemsControl.ItemTemplate>
                                            <DataTemplate>
                                                <!-- Outbound = right-aligned; inbound = left-aligned -->
                                                <Grid Margin="0,0,0,12">
                                                    <!-- Inbound bubble (left) -->
                                                    <StackPanel MaxWidth="520" HorizontalAlignment="Left">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Visible" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsOutbound}" Value="True">
                                                                        <Setter Property="Visibility" Value="Collapsed" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <TextBlock Text="{Binding Sender}"
                                                                   FontSize="10" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource AccentSoftBrush}"
                                                                   Margin="4,0,0,3" />
                                                        <Border Background="#161b22"
                                                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                                                BorderThickness="1"
                                                                CornerRadius="0,8,8,8"
                                                                Padding="12,8">
                                                            <TextBlock Text="{Binding Body}"
                                                                       FontSize="12"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       TextWrapping="Wrap"
                                                                       FontFamily="Consolas" />
                                                        </Border>
                                                        <TextBlock Text="{Binding Timestamp}"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource TextSubtleBrush}"
                                                                   Margin="4,3,0,0" />
                                                    </StackPanel>

                                                    <!-- Outbound bubble (right) -->
                                                    <StackPanel MaxWidth="520" HorizontalAlignment="Right">
                                                        <StackPanel.Style>
                                                            <Style TargetType="StackPanel">
                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                <Style.Triggers>
                                                                    <DataTrigger Binding="{Binding IsOutbound}" Value="True">
                                                                        <Setter Property="Visibility" Value="Visible" />
                                                                    </DataTrigger>
                                                                </Style.Triggers>
                                                            </Style>
                                                        </StackPanel.Style>
                                                        <TextBlock Text="{Binding Sender}"
                                                                   FontSize="10" FontWeight="SemiBold"
                                                                   Foreground="{StaticResource TextMutedBrush}"
                                                                   HorizontalAlignment="Right"
                                                                   Margin="0,0,4,3" />
                                                        <Border Background="#1c2735"
                                                                BorderBrush="#1f6feb"
                                                                BorderThickness="1"
                                                                CornerRadius="8,0,8,8"
                                                                Padding="12,8">
                                                            <TextBlock Text="{Binding Body}"
                                                                       FontSize="12"
                                                                       Foreground="{StaticResource TextPrimaryBrush}"
                                                                       TextWrapping="Wrap"
                                                                       FontFamily="Consolas" />
                                                        </Border>
                                                        <TextBlock Text="{Binding Timestamp}"
                                                                   FontSize="10"
                                                                   Foreground="{StaticResource TextSubtleBrush}"
                                                                   HorizontalAlignment="Right"
                                                                   Margin="0,3,4,0" />
                                                    </StackPanel>
                                                </Grid>
                                            </DataTemplate>
                                        </ItemsControl.ItemTemplate>
                                    </ItemsControl>

                                </StackPanel>
                            </ScrollViewer>

                            <!-- Compose area -->
                            <Border Grid.Row="2"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderSubtleBrush}"
                                    BorderThickness="0,1,0,0"
                                    Padding="16,12">
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*" />
                                        <ColumnDefinition Width="12" />
                                        <ColumnDefinition Width="Auto" />
                                    </Grid.ColumnDefinitions>
                                    <Border Grid.Column="0"
                                            Background="{StaticResource HeroCardBrush}"
                                            BorderBrush="{StaticResource BorderSubtleBrush}"
                                            BorderThickness="1"
                                            CornerRadius="6"
                                            Padding="12,6">
                                        <TextBlock Text="Free-text ACARS messaging coming in a future update."
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSubtleBrush}"
                                                   VerticalAlignment="Center" />
                                    </Border>
                                    <Button Grid.Column="2"
                                            Content="Send"
                                            IsEnabled="False"
                                            Style="{StaticResource ShellActionButtonStyle}" />
                                </Grid>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ── LIVE MAP (WebView2 → simcrewops.com/tracker-map) ── -->
                    <Border Visibility="{Binding IsLiveMapVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Background="{StaticResource SurfaceBrush}" CornerRadius="8"
                            BorderBrush="{StaticResource DividerBrush}" BorderThickness="1"
                            ClipToBounds="True">
                        <wv2:WebView2 Source="{Binding LiveMapUri}" />
                    </Border>

                    <!-- ── POST-FLIGHT REVIEW (Option 4 — Split Panel) ─── -->
                    <Border Visibility="{Binding IsReviewVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Style="{StaticResource DarkCardStyle}" Padding="0">
                        <Grid>
                            <Grid.RowDefinitions>
                                <!-- Top bar -->
                                <RowDefinition Height="Auto" />
                                <!-- Auto-fail banner (collapsed when not needed) -->
                                <RowDefinition Height="Auto" />
                                <!-- Body -->
                                <RowDefinition Height="*" />
                            </Grid.RowDefinitions>

                            <!-- ── Top bar: route + status ─────────────────── -->
                            <Border Grid.Row="0"
                                    Background="{StaticResource SurfaceBrush}"
                                    BorderBrush="{StaticResource BorderSubtleBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="20,12">
                                <Grid>
                                    <TextBlock Text="{Binding ReviewHeaderRoute}"
                                               FontSize="12" FontWeight="SemiBold"
                                               Foreground="{StaticResource TextMutedBrush}"
                                               VerticalAlignment="Center" />
                                    <Border HorizontalAlignment="Right"
                                            Background="#1a3326"
                                            BorderBrush="#2d6e2d"
                                            BorderThickness="1"
                                            CornerRadius="20"
                                            Padding="10,3">
                                        <TextBlock Text="✓  Session complete"
                                                   FontSize="11" FontWeight="Bold"
                                                   Foreground="{StaticResource SuccessBrush}" />
                                    </Border>
                                </Grid>
                            </Border>

                            <!-- ── Auto-fail banner ────────────────────────── -->
                            <Border Grid.Row="1"
                                    Visibility="{Binding AutoFailBannerVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                                    Background="{StaticResource DangerSoftBrush}"
                                    BorderBrush="{StaticResource DangerBrush}"
                                    BorderThickness="0,0,0,1"
                                    Padding="20,10">
                                <TextBlock Text="⚠  AUTOMATIC FAIL — hard landing or critical violation recorded"
                                           FontSize="13" FontWeight="SemiBold"
                                           Foreground="{StaticResource DangerBrush}" />
                            </Border>

                            <!-- ── Two-column body ─────────────────────────── -->
                            <Grid Grid.Row="2">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="1" />
                                    <ColumnDefinition Width="*" />
                                </Grid.ColumnDefinitions>

                                <!-- ── LEFT: grade + landing data ─────────── -->
                                <ScrollViewer Grid.Column="0"
                                              VerticalScrollBarVisibility="Auto"
                                              Padding="20,18,20,20">
                                    <StackPanel>

                                        <!-- Grade badge + score -->
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto" />
                                                <ColumnDefinition Width="*" />
                                            </Grid.ColumnDefinitions>
                                            <Border Background="{Binding GradeBrush}"
                                                    CornerRadius="12"
                                                    Width="60" Height="60"
                                                    VerticalAlignment="Center">
                                                <TextBlock Text="{Binding GradeLetter}"
                                                           FontSize="28" FontWeight="Black"
                                                           Foreground="White"
                                                           HorizontalAlignment="Center"
                                                           VerticalAlignment="Center" />
                                            </Border>
                                            <StackPanel Grid.Column="1"
                                                        VerticalAlignment="Center"
                                                        Margin="14,0,0,0">
                                                <StackPanel Orientation="Horizontal">
                                                    <TextBlock Text="{Binding ScoreText}"
                                                               FontSize="36" FontWeight="Black"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontFamily="Consolas" />
                                                    <TextBlock Text=" / 100"
                                                               FontSize="18"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               VerticalAlignment="Bottom"
                                                               Margin="3,0,0,5" />
                                                </StackPanel>
                                                <TextBlock Text="{Binding ReviewSummary}"
                                                           FontSize="11"
                                                           Foreground="{StaticResource TextMutedBrush}" />
                                            </StackPanel>
                                        </Grid>

                                        <!-- Landing metric list -->
                                        <Border Background="{StaticResource HeroCardBrush}"
                                                BorderBrush="{StaticResource BorderSubtleBrush}"
                                                BorderThickness="1"
                                                CornerRadius="8"
                                                Margin="0,16,0,0">
                                            <!-- Each row: label left, value right -->
                                            <StackPanel>
                                                <Grid Style="{StaticResource MetricListRowStyle}">
                                                    <TextBlock Text="Vert Speed" Style="{StaticResource MetricListLabelStyle}" />
                                                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center"
                                                                Orientation="Horizontal" Margin="0,0,14,0">
                                                        <TextBlock Text="{Binding LandingFpm}"
                                                                   FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                                                   Foreground="{Binding LandingFpmBrush}" />
                                                        <TextBlock Text=" fpm" FontSize="12"
                                                                   Foreground="{StaticResource TextSubtleBrush}"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Grid>
                                                <Border Style="{StaticResource MetricListDividerStyle}" />
                                                <Grid Style="{StaticResource MetricListRowStyle}">
                                                    <TextBlock Text="G-Force" Style="{StaticResource MetricListLabelStyle}" />
                                                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center"
                                                                Orientation="Horizontal" Margin="0,0,14,0">
                                                        <TextBlock Text="{Binding LandingGForce}"
                                                                   FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                                                   Foreground="{Binding LandingGForceBrush}" />
                                                        <TextBlock Text=" G" FontSize="12"
                                                                   Foreground="{StaticResource TextSubtleBrush}"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Grid>
                                                <Border Style="{StaticResource MetricListDividerStyle}" />
                                                <Grid Style="{StaticResource MetricListRowStyle}">
                                                    <TextBlock Text="Ref Speed" Style="{StaticResource MetricListLabelStyle}" />
                                                    <StackPanel HorizontalAlignment="Right" VerticalAlignment="Center"
                                                                Orientation="Horizontal" Margin="0,0,14,0">
                                                        <TextBlock Text="{Binding LandingIas}"
                                                                   FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                                        <TextBlock Text=" kts" FontSize="12"
                                                                   Foreground="{StaticResource TextSubtleBrush}"
                                                                   VerticalAlignment="Center" />
                                                    </StackPanel>
                                                </Grid>
                                                <Border Style="{StaticResource MetricListDividerStyle}" />
                                                <Grid Style="{StaticResource MetricListRowStyle}">
                                                    <TextBlock Text="Bounces" Style="{StaticResource MetricListLabelStyle}" />
                                                    <TextBlock Text="{Binding LandingBounces}"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                                               Margin="0,0,14,0"
                                                               FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                                               Foreground="{Binding LandingBouncesBrush}" />
                                                </Grid>
                                                <Border Style="{StaticResource MetricListDividerStyle}" />
                                                <Grid Style="{StaticResource MetricListRowStyle}">
                                                    <TextBlock Text="Bank" Style="{StaticResource MetricListLabelStyle}" />
                                                    <TextBlock Text="{Binding LandingBankAngle}"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                                               Margin="0,0,14,0"
                                                               FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                                </Grid>
                                                <Border Style="{StaticResource MetricListDividerStyle}" />
                                                <Grid Style="{StaticResource MetricListRowStyle}">
                                                    <TextBlock Text="Pitch" Style="{StaticResource MetricListLabelStyle}" />
                                                    <TextBlock Text="{Binding LandingPitchAngle}"
                                                               HorizontalAlignment="Right" VerticalAlignment="Center"
                                                               Margin="0,0,14,0"
                                                               FontFamily="Consolas" FontSize="14" FontWeight="Bold"
                                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                                </Grid>
                                            </StackPanel>
                                        </Border>

                                        <!-- TDZ position -->
                                        <TextBlock Text="TDZ POSITION"
                                                   Style="{StaticResource SectionLabelStyle}"
                                                   Margin="0,16,0,6" />
                                        <Canvas Height="22" HorizontalAlignment="Stretch">
                                            <Border Canvas.Left="0" Canvas.Top="0"
                                                    Width="240" Height="22"
                                                    Background="#1c2128" CornerRadius="4" />
                                            <Border Canvas.Left="0" Canvas.Top="0"
                                                    Width="{Binding RunwayTdzWidth}" Height="22"
                                                    Background="#1a3326" CornerRadius="4,0,0,4" />
                                            <TextBlock Canvas.Left="5" Canvas.Top="4"
                                                       Text="TDZ" FontSize="9" FontWeight="Bold"
                                                       Foreground="#3fb950" />
                                            <Border Width="3" Height="18" Canvas.Top="2"
                                                    Canvas.Left="{Binding RunwayMarkerLeft}"
                                                    Background="{Binding RunwayMarkerBrush}"
                                                    CornerRadius="1" />
                                        </Canvas>
                                        <Grid Margin="0,5,0,0">
                                            <TextBlock Text="Threshold"
                                                       FontSize="9"
                                                       Foreground="{StaticResource TextSubtleBrush}" />
                                            <TextBlock Text="{Binding LandingTzExcess}"
                                                       FontSize="9" FontWeight="SemiBold"
                                                       HorizontalAlignment="Right"
                                                       Foreground="{Binding RunwayMarkerBrush}" />
                                        </Grid>

                                    </StackPanel>
                                </ScrollViewer>

                                <!-- Column divider -->
                                <Border Grid.Column="1"
                                        Background="{StaticResource BorderSubtleBrush}" />

                                <!-- ── RIGHT: phase breakdown ──────────────── -->
                                <ScrollViewer Grid.Column="2"
                                              VerticalScrollBarVisibility="Auto"
                                              Padding="20,18,20,20">
                                    <StackPanel>
                                        <TextBlock Text="PHASE BREAKDOWN"
                                                   Style="{StaticResource SectionLabelStyle}"
                                                   Margin="0,0,0,12" />
                                        <ItemsControl ItemsSource="{Binding ReviewScoreRows}">
                                            <ItemsControl.ItemTemplate>
                                                <DataTemplate DataType="{x:Type model:ScoreRowModel}">
                                                    <Border Background="{StaticResource HeroCardBrush}"
                                                            BorderBrush="{StaticResource BorderSubtleBrush}"
                                                            BorderThickness="1"
                                                            CornerRadius="8"
                                                            Padding="12,10"
                                                            Margin="0,0,0,8">
                                                        <StackPanel>
                                                            <!-- Phase name + score -->
                                                            <Grid>
                                                                <TextBlock Text="{Binding Label}"
                                                                           FontSize="13" FontWeight="SemiBold"
                                                                           Foreground="{StaticResource TextPrimaryBrush}" />
                                                                <TextBlock Text="{Binding ScoreText}"
                                                                           HorizontalAlignment="Right"
                                                                           FontFamily="Consolas" FontSize="13" FontWeight="Bold"
                                                                           Foreground="{Binding FillBrush}" />
                                                            </Grid>
                                                            <!-- Progress bar -->
                                                            <Grid Height="5" Margin="0,6,0,0">
                                                                <Border Background="#1c2128" CornerRadius="3" />
                                                                <Border Background="{Binding FillBrush}"
                                                                        CornerRadius="3"
                                                                        Width="{Binding FillWidth}"
                                                                        HorizontalAlignment="Left" />
                                                            </Grid>
                                                            <!-- Finding text (hidden when empty) -->
                                                            <TextBlock Text="{Binding FindingText}"
                                                                       FontSize="11"
                                                                       Foreground="{StaticResource AmberBrush}"
                                                                       Margin="0,5,0,0"
                                                                       TextWrapping="Wrap">
                                                                <TextBlock.Style>
                                                                    <Style TargetType="TextBlock">
                                                                        <Style.Triggers>
                                                                            <DataTrigger Binding="{Binding FindingText}" Value="">
                                                                                <Setter Property="Visibility" Value="Collapsed" />
                                                                            </DataTrigger>
                                                                        </Style.Triggers>
                                                                    </Style>
                                                                </TextBlock.Style>
                                                            </TextBlock>
                                                        </StackPanel>
                                                    </Border>
                                                </DataTemplate>
                                            </ItemsControl.ItemTemplate>
                                        </ItemsControl>
                                    </StackPanel>
                                </ScrollViewer>

                            </Grid>
                        </Grid>
                    </Border>

                    <!-- ── DIAGNOSTICS ───────────────────────────────────── -->
                    <Border Visibility="{Binding IsDiagnosticsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Background="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource DarkCardStyle}" Padding="18">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="SIM STATUS" Style="{StaticResource SectionLabelStyle}" />
                                        <TextBlock Text="{Binding DiagnosticsSimState}" Margin="0,10,0,0" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="TELEMETRY DEBUG" Margin="0,20,0,8" Style="{StaticResource SectionLabelStyle}" />
                                        <TextBlock Text="{Binding DiagnosticsTelemetryClient}" Foreground="{StaticResource TextMutedBrush}" FontSize="13" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding DiagnosticsTelemetryFlow}" Margin="0,6,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="13" TextWrapping="Wrap" />
                                        <TextBlock Text="{Binding DiagnosticsTelemetryCounters}" Margin="0,6,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="13" TextWrapping="Wrap" />
                                        <TextBlock Text="LAST TELEMETRY" Margin="0,20,0,8" Style="{StaticResource SectionLabelStyle}" />
                                        <TextBlock Text="{Binding DiagnosticsLastTelemetry}" Foreground="{StaticResource TextMutedBrush}" FontSize="13" TextWrapping="Wrap" />
                                        <TextBlock Text="RAW FRAME" Margin="0,20,0,8" Style="{StaticResource SectionLabelStyle}" />
                                        <TextBlock Text="{Binding DiagnosticsRawTelemetry}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontFamily="Consolas" TextWrapping="Wrap" />
                                        <TextBlock Text="RECOVERY" Margin="0,20,0,8" Style="{StaticResource SectionLabelStyle}" />
                                        <TextBlock Text="{Binding DiagnosticsRecoveryState}" Foreground="{StaticResource TextMutedBrush}" FontSize="13" TextWrapping="Wrap" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource DarkCardStyle}" Padding="18">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="SYNC" Style="{StaticResource SectionLabelStyle}" />
                                        <TextBlock Text="{Binding DiagnosticsSyncState}" Margin="0,10,0,0" Foreground="{StaticResource TextPrimaryBrush}" FontSize="14" FontWeight="SemiBold" TextWrapping="Wrap" />
                                        <TextBlock Text="SETTINGS FILE" Margin="0,20,0,8" Style="{StaticResource SectionLabelStyle}" />
                                        <TextBlock Text="{Binding DiagnosticsSettingsPath}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontFamily="Consolas" TextWrapping="Wrap" />
                                        <TextBlock Text="STORAGE ROOT" Margin="0,20,0,8" Style="{StaticResource SectionLabelStyle}" />
                                        <TextBlock Text="{Binding DiagnosticsStoragePath}" Foreground="{StaticResource TextMutedBrush}" FontSize="12" FontFamily="Consolas" TextWrapping="Wrap" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Border>

                    <!-- ── SETTINGS ──────────────────────────────────────── -->
                    <Border Visibility="{Binding IsSettingsVisible, Converter={StaticResource BooleanToVisibilityConverter}}"
                            Background="Transparent">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="16" />
                                <ColumnDefinition Width="*" />
                            </Grid.ColumnDefinitions>
                            <Border Style="{StaticResource DarkCardStyle}" Padding="18">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="API &amp; SYNC" Style="{StaticResource SectionLabelStyle}" />
                                        <TextBlock Text="Base URL" Margin="0,14,0,5" Foreground="{StaticResource NavTextBrush}" FontSize="13" />
                                        <TextBox Text="{Binding SettingsEditor.BaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Sim Sessions Path" Margin="0,14,0,5" Foreground="{StaticResource NavTextBrush}" FontSize="13" />
                                        <TextBox Text="{Binding SettingsEditor.SimSessionsPath, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Pilot API Token" Margin="0,14,0,4" Foreground="{StaticResource NavTextBrush}" FontSize="13" />
                                        <TextBlock Margin="0,0,0,5" FontSize="11" Foreground="{StaticResource TextMutedBrush}" TextWrapping="Wrap">
                                            <Run Text="Copy from " />
                                            <Hyperlink Command="{Binding OpenAccountSettingsCommand}" Foreground="{StaticResource AccentSoftBrush}">simcrewops.com/settings</Hyperlink>
                                            <Run Text=" → Connect Tracker." />
                                        </TextBlock>
                                        <TextBox Text="{Binding SettingsEditor.PilotApiToken, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="App Version" Margin="0,14,0,4" Foreground="{StaticResource NavTextBrush}" FontSize="13" />
                                        <TextBlock Text="{x:Static vm:MainWindowViewModel.AppVersion}"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   FontFamily="Consolas"
                                                   FontSize="12" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                            <Border Grid.Column="2" Style="{StaticResource DarkCardStyle}" Padding="18">
                                <ScrollViewer VerticalScrollBarVisibility="Auto">
                                    <StackPanel>
                                        <TextBlock Text="STORAGE" Style="{StaticResource SectionLabelStyle}" />
                                        <TextBlock Text="Storage Root Directory" Margin="0,14,0,5" Foreground="{StaticResource NavTextBrush}" FontSize="13" />
                                        <TextBox Text="{Binding SettingsEditor.StorageRootDirectory, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Background Sync Interval (seconds)" Margin="0,14,0,5" Foreground="{StaticResource NavTextBrush}" FontSize="13" />
                                        <TextBox Text="{Binding SettingsEditor.BackgroundSyncIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" />
                                        <TextBlock Text="Max Sessions Per Pass" Margin="0,14,0,5" Foreground="{StaticResource NavTextBrush}" FontSize="13" />
                                        <TextBox Text="{Binding SettingsEditor.MaxSessionsPerPass, UpdateSourceTrigger=PropertyChanged}" />
                                        <CheckBox Content="Enable background sync"
                                                  IsChecked="{Binding SettingsEditor.BackgroundSyncEnabled}"
                                                  Margin="0,16,0,0" FontSize="13" />
                                        <CheckBox Content="Enable telemetry diagnostics (debug)"
                                                  IsChecked="{Binding SettingsEditor.EnableTelemetryDiagnostics}"
                                                  Margin="0,10,0,0" FontSize="13" />
                                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                                            <Button Content="Save Settings" Command="{Binding SaveSettingsCommand}" Style="{StaticResource ShellActionButtonStyle}" />
                                            <Button Content="Retry Sync"    Command="{Binding RetrySyncCommand}"    Style="{StaticResource ShellActionButtonStyle}" />
                                        </StackPanel>
                                        <TextBlock Text="{Binding SettingsSaveStatus}" Margin="0,14,0,0" Foreground="{StaticResource TextMutedBrush}" FontSize="12" TextWrapping="Wrap" />
                                    </StackPanel>
                                </ScrollViewer>
                            </Border>
                        </Grid>
                    </Border>

                </Grid>
                <!-- end center+right grid -->

            </Grid>
            <!-- end content area -->
        </Grid>
        <!-- end main content -->

    </Grid>
</Window>
