<Window x:Class="SimCrewOps.App.Wpf.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:model="clr-namespace:SimCrewOps.App.Wpf.Models"
        xmlns:vm="clr-namespace:SimCrewOps.App.Wpf.ViewModels"
        mc:Ignorable="d"
        Title="SimCrewOps Tracker"
        Width="1440"
        Height="960"
        MinWidth="1100"
        MinHeight="740"
        Background="{StaticResource BgBaseBrush}">

    <Window.Resources>

        <!-- Metric tile card (phase grid) -->
        <Style x:Key="MetricTileStyle" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource BgElevatedBrush}" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius"    Value="10" />
            <Setter Property="Padding"         Value="12,10" />
            <Setter Property="Margin"          Value="0,0,8,8" />
        </Style>

        <!-- Phase pill (inactive) -->
        <Style x:Key="PhasePillStyle" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource BgElevatedBrush}" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius"    Value="12" />
            <Setter Property="Padding"         Value="10,4" />
            <Setter Property="Margin"          Value="0,0,6,6" />
        </Style>

        <!-- Light/status indicator pill -->
        <Style x:Key="StatusPillStyle" TargetType="Border">
            <Setter Property="Background"      Value="{StaticResource BgMutedBrush}" />
            <Setter Property="BorderBrush"     Value="{StaticResource BorderDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="CornerRadius"    Value="6" />
            <Setter Property="Padding"         Value="10,4" />
            <Setter Property="Margin"          Value="0,0,6,0" />
        </Style>

    </Window.Resources>

    <Grid Margin="14">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />  <!-- Identity bar -->
            <RowDefinition Height="12" />
            <RowDefinition Height="*" />     <!-- Main content -->
            <RowDefinition Height="12" />
            <RowDefinition Height="44" />    <!-- Nav footer -->
        </Grid.RowDefinitions>

        <!-- ═══════════════════════════════════════════════════════
             ROW 0 — IDENTITY BAR
        ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="0"
                Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="14"
                Padding="22,14">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="Auto" />
                </Grid.ColumnDefinitions>

                <!-- Left: flight number + route + aircraft -->
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,0,0">

                    <!-- Flight number -->
                    <TextBlock Text="{Binding HeaderFlightText}"
                               FontSize="28"
                               FontWeight="Black"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center" />

                    <!-- Divider -->
                    <Border Width="1" Background="{StaticResource BorderDefaultBrush}" Margin="18,4" />

                    <!-- Route -->
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <StackPanel>
                            <TextBlock Text="{Binding DepartureIcao}"
                                       FontSize="22"
                                       FontWeight="ExtraBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding DepartureName}"
                                       FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                        <TextBlock Text="→"
                                   FontSize="16"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource AccentOrangeBrush}"
                                   VerticalAlignment="Center"
                                   Margin="10,0" />
                        <StackPanel>
                            <TextBlock Text="{Binding ArrivalIcao}"
                                       FontSize="22"
                                       FontWeight="ExtraBold"
                                       Foreground="{StaticResource TextPrimaryBrush}" />
                            <TextBlock Text="{Binding ArrivalName}"
                                       FontSize="10"
                                       Foreground="{StaticResource TextMutedBrush}"
                                       Margin="0,2,0,0" />
                        </StackPanel>
                    </StackPanel>

                    <!-- Divider -->
                    <Border Width="1" Background="{StaticResource BorderDefaultBrush}" Margin="18,4" />

                    <!-- Aircraft -->
                    <StackPanel VerticalAlignment="Center">
                        <TextBlock Text="{Binding AircraftType}"
                                   FontSize="20"
                                   FontWeight="ExtraBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" />
                        <TextBlock Text="AIRCRAFT"
                                   FontSize="9"
                                   FontWeight="Bold"
                                   Foreground="{StaticResource TextMutedBrush}"
                                   Margin="0,3,0,0" />
                    </StackPanel>
                </StackPanel>

                <!-- Right: status pills -->
                <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Background="{StaticResource BgElevatedBrush}"
                            BorderBrush="{StaticResource BorderDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="99"
                            Padding="12,5"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7"
                                     Fill="{Binding MsfsStatusBrush}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,6,0" />
                            <TextBlock Text="{Binding MsfsStatusText}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                    <Border Background="{StaticResource BgElevatedBrush}"
                            BorderBrush="{StaticResource BorderDefaultBrush}"
                            BorderThickness="1"
                            CornerRadius="99"
                            Padding="12,5">
                        <StackPanel Orientation="Horizontal">
                            <Ellipse Width="7" Height="7"
                                     Fill="{Binding SyncStatusBrush}"
                                     VerticalAlignment="Center"
                                     Margin="0,0,6,0" />
                            <TextBlock Text="{Binding SyncStatusText}"
                                       FontSize="11"
                                       FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}" />
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══════════════════════════════════════════════════════
             ROW 2 — MAIN CONTENT
        ═══════════════════════════════════════════════════════ -->
        <Grid Grid.Row="2">
            <Grid Visibility="{Binding IsDashboardVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*" />
                    <ColumnDefinition Width="12" />
                    <ColumnDefinition Width="320" />
                </Grid.ColumnDefinitions>

                <!-- ── Left column ── -->
                <Grid Grid.Column="0">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />  <!-- Phase hero -->
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />  <!-- Key metrics -->
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />  <!-- Secondary metrics -->
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />  <!-- Lights + systems strip -->
                    </Grid.RowDefinitions>

                    <!-- Phase hero -->
                    <Border Grid.Row="0" Style="{StaticResource CardStyle}" Padding="22,18">
                        <Grid>
                            <Grid.RowDefinitions>
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="10" />
                                <RowDefinition Height="Auto" />
                                <RowDefinition Height="6" />
                                <RowDefinition Height="Auto" />
                            </Grid.RowDefinitions>

                            <TextBlock Grid.Row="0"
                                       Text="CURRENT PHASE"
                                       Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Grid.Row="1"
                                       Text="{Binding PhaseTitle}"
                                       FontSize="32"
                                       FontWeight="Black"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,6,0,0" />
                            <TextBlock Grid.Row="2"
                                       Text="{Binding PhaseSubtitle}"
                                       FontSize="13"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       Margin="0,4,0,0"
                                       TextWrapping="Wrap" />

                            <!-- Phase progress strip -->
                            <ItemsControl Grid.Row="4" ItemsSource="{Binding PhasePills}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type model:PhasePillModel}">
                                        <Border Height="4" Width="60" Margin="0,0,3,0" CornerRadius="2">
                                            <Border.Style>
                                                <Style TargetType="Border">
                                                    <Setter Property="Background" Value="{StaticResource BgMutedBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource AccentOrangeBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource AccentGreenBrush}" />
                                                            <Setter Property="Opacity" Value="0.5" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Border.Style>
                                        </Border>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                            <!-- Phase labels -->
                            <ItemsControl Grid.Row="6" ItemsSource="{Binding PhasePills}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type model:PhasePillModel}">
                                        <TextBlock Text="{Binding Label}"
                                                   Width="63"
                                                   FontSize="9"
                                                   FontWeight="Bold"
                                                   TextAlignment="Center">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsActive}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentOrangeBrush}" />
                                                        </DataTrigger>
                                                        <DataTrigger Binding="{Binding IsDone}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}" />
                                                            <Setter Property="Opacity" Value="0.6" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>

                        </Grid>
                    </Border>

                    <!-- Key metrics (3 large cards) -->
                    <ItemsControl Grid.Row="2" ItemsSource="{Binding MetricTiles}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type model:MetricTileModel}">
                                <Border Margin="0,0,10,0" CornerRadius="14" Padding="16,14">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background"      Value="{StaticResource BgSurfaceBrush}" />
                                            <Setter Property="BorderBrush"     Value="{StaticResource BorderDefaultBrush}" />
                                            <Setter Property="BorderThickness" Value="1" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding IsAlert}" Value="True">
                                                    <Setter Property="Background"  Value="#170a0a" />
                                                    <Setter Property="BorderBrush" Value="#4d1010" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}"
                                                   Style="{StaticResource SectionLabelStyle}"
                                                   Margin="0,0,0,8" />
                                        <TextBlock Text="{Binding Value}"
                                                   FontSize="30"
                                                   FontWeight="Black">
                                            <TextBlock.Style>
                                                <Style TargetType="TextBlock">
                                                    <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsAlert}" Value="True">
                                                            <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </TextBlock.Style>
                                        </TextBlock>
                                        <TextBlock Text="{Binding Unit}"
                                                   FontSize="12"
                                                   Foreground="{StaticResource TextSecondaryBrush}"
                                                   Margin="0,4,0,0" />
                                        <TextBlock Text="{Binding Hint}"
                                                   FontSize="11"
                                                   Foreground="{StaticResource TextMutedBrush}"
                                                   Margin="0,5,0,0"
                                                   TextWrapping="Wrap" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Secondary metrics (5 smaller tiles) -->
                    <ItemsControl Grid.Row="4" ItemsSource="{Binding StatusChips}">
                        <ItemsControl.ItemsPanel>
                            <ItemsPanelTemplate>
                                <UniformGrid Rows="1" />
                            </ItemsPanelTemplate>
                        </ItemsControl.ItemsPanel>
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,8,0" Padding="12,10">
                                    <StackPanel>
                                        <TextBlock Text="{Binding Label}"
                                                   Style="{StaticResource SectionLabelStyle}"
                                                   Margin="0,0,0,5" />
                                        <TextBlock Text="{Binding Value}"
                                                   FontSize="16"
                                                   FontWeight="Bold"
                                                   Foreground="{StaticResource TextPrimaryBrush}" />
                                    </StackPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>

                    <!-- Lights + parking brake strip -->
                    <Border Grid.Row="6"
                            Style="{StaticResource CardStyle}"
                            Padding="14,10">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <TextBlock Text="LIGHTS"
                                       Style="{StaticResource SectionLabelStyle}"
                                       VerticalAlignment="Center"
                                       Margin="0,0,14,0" />

                            <!-- Beacon -->
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource StatusPillStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding BeaconLightOn}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource LightRedBgBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentRedBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,5,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{StaticResource TextMutedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding BeaconLightOn}" Value="True">
                                                        <Setter Property="Fill" Value="{StaticResource AccentRedBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="Beacon" FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding BeaconLightOn}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Taxi -->
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource StatusPillStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding TaxiLightOn}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource LightWhiteBgBrush}" />
                                                <Setter Property="BorderBrush" Value="#4a5568" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,5,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{StaticResource TextMutedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TaxiLightOn}" Value="True">
                                                        <Setter Property="Fill" Value="{StaticResource TextPrimaryBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="Taxi" FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding TaxiLightOn}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Strobe -->
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource StatusPillStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding StrobeLightOn}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource LightWhiteBgBrush}" />
                                                <Setter Property="BorderBrush" Value="#4a5568" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,5,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{StaticResource TextMutedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StrobeLightOn}" Value="True">
                                                        <Setter Property="Fill" Value="{StaticResource TextPrimaryBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="Strobe" FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding StrobeLightOn}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Landing -->
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource StatusPillStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding LandingLightOn}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource LightWhiteBgBrush}" />
                                                <Setter Property="BorderBrush" Value="#4a5568" />
                                            </DataTrigger>
                                            <DataTrigger Binding="{Binding LandingLightViolation}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource LightAmberBgBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentAmberBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,5,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{StaticResource TextMutedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LandingLightOn}" Value="True">
                                                        <Setter Property="Fill" Value="{StaticResource TextPrimaryBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding LandingLightViolation}" Value="True">
                                                        <Setter Property="Fill" Value="{StaticResource AccentAmberBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text"       Value="Landing" />
                                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LandingLightOn}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
                                                    </DataTrigger>
                                                    <DataTrigger Binding="{Binding LandingLightViolation}" Value="True">
                                                        <Setter Property="Text"       Value="Landing ⚠" />
                                                        <Setter Property="Foreground" Value="{StaticResource AccentAmberBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                            <!-- Divider -->
                            <Border Width="1" Background="{StaticResource BorderDefaultBrush}" Margin="10,3" />

                            <!-- Parking Brake -->
                            <Border>
                                <Border.Style>
                                    <Style TargetType="Border" BasedOn="{StaticResource StatusPillStyle}">
                                        <Style.Triggers>
                                            <DataTrigger Binding="{Binding ParkingBrakeSet}" Value="True">
                                                <Setter Property="Background" Value="{StaticResource LightRedBgBrush}" />
                                                <Setter Property="BorderBrush" Value="{StaticResource AccentRedBrush}" />
                                            </DataTrigger>
                                        </Style.Triggers>
                                    </Style>
                                </Border.Style>
                                <StackPanel Orientation="Horizontal">
                                    <Ellipse Width="7" Height="7" VerticalAlignment="Center" Margin="0,0,5,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{StaticResource TextMutedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ParkingBrakeSet}" Value="True">
                                                        <Setter Property="Fill" Value="{StaticResource AccentRedBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                    <TextBlock Text="Park Brake" FontSize="11" FontWeight="SemiBold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding ParkingBrakeSet}" Value="True">
                                                        <Setter Property="Foreground" Value="{StaticResource AccentRedBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </StackPanel>
                            </Border>

                        </StackPanel>
                    </Border>

                </Grid>

                <!-- ── Right column ── -->
                <Grid Grid.Column="2">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />  <!-- Alert -->
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />  <!-- Score -->
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />  <!-- Landing analyzer -->
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />  <!-- OOOI -->
                        <RowDefinition Height="10" />
                        <RowDefinition Height="Auto" />  <!-- Sync health -->
                    </Grid.RowDefinitions>

                    <!-- Primary alert -->
                    <Border Grid.Row="0" CornerRadius="14" Padding="16">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"      Value="{StaticResource AlertAmberBgBrush}" />
                                <Setter Property="BorderBrush"     Value="{StaticResource AlertAmberBorderBrush}" />
                                <Setter Property="BorderThickness" Value="1" />
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <TextBlock Text="{Binding AlertType}"
                                       Style="{StaticResource SectionLabelStyle}"
                                       Foreground="{StaticResource AccentAmberBrush}"
                                       Margin="0,0,0,8" />
                            <TextBlock Text="{Binding AlertPrimaryTitle}"
                                       FontSize="16"
                                       FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"
                                       Margin="0,0,0,6"
                                       TextWrapping="Wrap" />
                            <TextBlock Text="{Binding AlertPrimaryBody}"
                                       FontSize="12"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       TextWrapping="Wrap"
                                       LineHeight="18" />
                        </StackPanel>
                    </Border>

                    <!-- Score strip -->
                    <Border Grid.Row="2" Style="{StaticResource CardStyle}" Padding="16">
                        <StackPanel>
                            <Grid Margin="0,0,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="SCORE" Style="{StaticResource SectionLabelStyle}" VerticalAlignment="Center" />
                                <StackPanel Grid.Column="1" Orientation="Horizontal">
                                    <TextBlock Text="{Binding ScoreText}"
                                               FontSize="26"
                                               FontWeight="Black"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <TextBlock Text="{Binding GradeText}"
                                               FontSize="16"
                                               FontWeight="Black"
                                               Foreground="{StaticResource AccentOrangeBrush}"
                                               Margin="6,6,0,0" />
                                </StackPanel>
                            </Grid>
                            <!-- Score bar -->
                            <Border Height="6" CornerRadius="3" Background="{StaticResource BgMutedBrush}">
                                <Border Height="6" CornerRadius="3"
                                        Background="{StaticResource AccentOrangeBrush}"
                                        Width="{Binding ScoreBarWidth}"
                                        HorizontalAlignment="Left" />
                            </Border>
                            <!-- Score breakdown rows -->
                            <ItemsControl ItemsSource="{Binding PrimaryScoreRows}" Margin="0,12,0,0">
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate DataType="{x:Type model:ScoreRowModel}">
                                        <Grid Margin="0,0,0,8">
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="*" />
                                                <ColumnDefinition Width="80" />
                                                <ColumnDefinition Width="44" />
                                            </Grid.ColumnDefinitions>
                                            <TextBlock Text="{Binding Label}"
                                                       FontSize="12"
                                                       FontWeight="Medium"
                                                       Foreground="{StaticResource TextSecondaryBrush}"
                                                       VerticalAlignment="Center" />
                                            <Border Grid.Column="1" Height="4" CornerRadius="2"
                                                    Background="{StaticResource BgMutedBrush}"
                                                    VerticalAlignment="Center" Margin="8,0">
                                                <Border Height="4" CornerRadius="2"
                                                        Background="{Binding FillBrush}"
                                                        Width="{Binding FillWidth}"
                                                        HorizontalAlignment="Left" />
                                            </Border>
                                            <TextBlock Grid.Column="2"
                                                       Text="{Binding ScoreText}"
                                                       FontSize="11"
                                                       FontWeight="Bold"
                                                       Foreground="{StaticResource TextMutedBrush}"
                                                       HorizontalAlignment="Right"
                                                       VerticalAlignment="Center" />
                                        </Grid>
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </StackPanel>
                    </Border>

                    <!-- Landing analyzer -->
                    <Border Grid.Row="4" CornerRadius="14" Padding="16">
                        <Border.Style>
                            <Style TargetType="Border">
                                <Setter Property="Background"      Value="{StaticResource BgSurfaceBrush}" />
                                <Setter Property="BorderBrush"     Value="{StaticResource BorderDefaultBrush}" />
                                <Setter Property="BorderThickness" Value="1" />
                                <Style.Triggers>
                                    <DataTrigger Binding="{Binding LandingRecorded}" Value="True">
                                        <Setter Property="BorderBrush" Value="#0d4d26" />
                                    </DataTrigger>
                                </Style.Triggers>
                            </Style>
                        </Border.Style>
                        <StackPanel>
                            <!-- Header row -->
                            <Grid Margin="0,0,0,12">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="*" />
                                    <ColumnDefinition Width="Auto" />
                                </Grid.ColumnDefinitions>
                                <TextBlock Text="LANDING ANALYZER" Style="{StaticResource SectionLabelStyle}" VerticalAlignment="Center" />
                                <Border Grid.Column="1" CornerRadius="4" Padding="8,2">
                                    <Border.Style>
                                        <Style TargetType="Border">
                                            <Setter Property="Background" Value="{StaticResource BgMutedBrush}" />
                                            <Style.Triggers>
                                                <DataTrigger Binding="{Binding LandingRecorded}" Value="True">
                                                    <Setter Property="Background" Value="#0a170f" />
                                                </DataTrigger>
                                            </Style.Triggers>
                                        </Style>
                                    </Border.Style>
                                    <TextBlock FontSize="9" FontWeight="Bold">
                                        <TextBlock.Style>
                                            <Style TargetType="TextBlock">
                                                <Setter Property="Text"       Value="Waiting for touchdown" />
                                                <Setter Property="Foreground" Value="{StaticResource TextMutedBrush}" />
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding LandingRecorded}" Value="True">
                                                        <Setter Property="Text"       Value="RECORDED" />
                                                        <Setter Property="Foreground" Value="{StaticResource AccentGreenBrush}" />
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </TextBlock.Style>
                                    </TextBlock>
                                </Border>
                            </Grid>

                            <!-- 2-col metric grid -->
                            <UniformGrid Columns="2" Rows="3">
                                <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,4,4" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="TOUCHDOWN VS" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding TouchdownVS}" FontSize="18" FontWeight="ExtraBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="fpm" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource InnerCardStyle}" Margin="4,0,0,4" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="BANK ANGLE" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding TouchdownBank}" FontSize="18" FontWeight="ExtraBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="degrees" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,4,4" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="IAS" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding TouchdownIAS}" FontSize="18" FontWeight="ExtraBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="knots" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource InnerCardStyle}" Margin="4,0,0,4" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="G-FORCE" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding TouchdownGForce}" FontSize="18" FontWeight="ExtraBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="G" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource InnerCardStyle}" Margin="0,0,4,0" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="PITCH" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding TouchdownPitch}" FontSize="18" FontWeight="ExtraBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text="degrees" FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>
                                <Border Style="{StaticResource InnerCardStyle}" Margin="4,0,0,0" Padding="10,8">
                                    <StackPanel>
                                        <TextBlock Text="BOUNCES" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,4" />
                                        <TextBlock Text="{Binding TouchdownBounces}" FontSize="18" FontWeight="ExtraBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                        <TextBlock Text=" " FontSize="10" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" />
                                    </StackPanel>
                                </Border>
                            </UniformGrid>

                            <!-- TDZ row -->
                            <Border Style="{StaticResource InnerCardStyle}" Margin="0,8,0,0" Padding="10,10">
                                <Grid>
                                    <Grid.RowDefinitions>
                                        <RowDefinition Height="Auto" />
                                        <RowDefinition Height="8" />
                                        <RowDefinition Height="Auto" />
                                    </Grid.RowDefinitions>
                                    <Grid>
                                        <Grid.ColumnDefinitions>
                                            <ColumnDefinition Width="*" />
                                            <ColumnDefinition Width="Auto" />
                                        </Grid.ColumnDefinitions>
                                        <TextBlock Text="TOUCHDOWN ZONE" Style="{StaticResource SectionLabelStyle}" />
                                        <TextBlock Grid.Column="1" Text="{Binding LandingRunway}"
                                                   FontSize="9" FontWeight="Bold"
                                                   Foreground="{StaticResource TextMutedBrush}" />
                                    </Grid>
                                    <UniformGrid Grid.Row="2" Columns="3">
                                        <StackPanel>
                                            <TextBlock Text="FROM THRESHOLD" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding TdzDistanceFt}" FontSize="15" FontWeight="ExtraBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Text="ft" FontSize="9" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="CENTERLINE" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding TdzCrossTrackFt}" FontSize="15" FontWeight="ExtraBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Text="ft off" FontSize="9" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" />
                                        </StackPanel>
                                        <StackPanel>
                                            <TextBlock Text="TDZ EXCESS" Style="{StaticResource SectionLabelStyle}" Margin="0,0,0,4" />
                                            <TextBlock Text="{Binding TdzExcessFt}" FontSize="15" FontWeight="ExtraBold" Foreground="{StaticResource TextPrimaryBrush}" />
                                            <TextBlock Text="ft past 3000" FontSize="9" Foreground="{StaticResource TextMutedBrush}" Margin="0,2,0,0" />
                                        </StackPanel>
                                    </UniformGrid>
                                </Grid>
                            </Border>

                        </StackPanel>
                    </Border>

                    <!-- OOOI strip -->
                    <Border Grid.Row="6" Style="{StaticResource CardStyle}" Padding="14,12">
                        <UniformGrid Columns="4">
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="OUT" Style="{StaticResource SectionLabelStyle}" HorizontalAlignment="Center" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding OutTime}" Style="{StaticResource MonoValueStyle}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="OFF" Style="{StaticResource SectionLabelStyle}" HorizontalAlignment="Center" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding OffTime}" Style="{StaticResource MonoValueStyle}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="ON" Style="{StaticResource SectionLabelStyle}" HorizontalAlignment="Center" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding OnTime}" Style="{StaticResource MonoValueStyle}" HorizontalAlignment="Center" />
                            </StackPanel>
                            <StackPanel HorizontalAlignment="Center">
                                <TextBlock Text="IN" Style="{StaticResource SectionLabelStyle}" HorizontalAlignment="Center" Margin="0,0,0,4" />
                                <TextBlock Text="{Binding InTime}" Style="{StaticResource MonoValueStyle}" HorizontalAlignment="Center" />
                            </StackPanel>
                        </UniformGrid>
                    </Border>

                    <!-- Sync health -->
                    <Border Grid.Row="8" Style="{StaticResource InnerCardStyle}" Padding="12,9">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*" />
                                <ColumnDefinition Width="Auto" />
                            </Grid.ColumnDefinitions>
                            <TextBlock Text="API Sync"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"
                                       VerticalAlignment="Center" />
                            <TextBlock Grid.Column="1"
                                       Text="{Binding SyncStatusText}"
                                       FontSize="11" FontWeight="SemiBold"
                                       Foreground="{StaticResource AccentGreenBrush}"
                                       VerticalAlignment="Center" />
                        </Grid>
                    </Border>

                </Grid>
            </Grid>

            <!-- ── Post-Flight Review ── -->
            <Border Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="1" CornerRadius="16" Padding="28"
                    Visibility="{Binding IsReviewVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                    </Grid.RowDefinitions>
                    <TextBlock Text="POST-FLIGHT REVIEW" Style="{StaticResource SectionLabelStyle}" />
                    <TextBlock Grid.Row="1" Text="{Binding ReviewSummary}"
                               Margin="0,12,0,0" FontSize="16" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}" />
                    <TextBlock Grid.Row="1" Text="{Binding ReviewLandingMetrics}"
                               Margin="0,40,0,0" FontSize="13"
                               Foreground="{StaticResource TextSecondaryBrush}" />
                    <ItemsControl Grid.Row="2" ItemsSource="{Binding ReviewScoreRows}" Margin="0,24,0,0">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate DataType="{x:Type model:ScoreRowModel}">
                                <Grid Margin="0,0,0,14">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="140" />
                                        <ColumnDefinition Width="220" />
                                        <ColumnDefinition Width="*" />
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Text="{Binding Label}"
                                               FontSize="15" FontWeight="Bold"
                                               Foreground="{StaticResource TextPrimaryBrush}" />
                                    <Border Grid.Column="1" Height="6" CornerRadius="3"
                                            Background="{StaticResource BgMutedBrush}"
                                            VerticalAlignment="Center" Margin="12,0,0,0">
                                        <Border Height="6" CornerRadius="3"
                                                Background="{Binding FillBrush}"
                                                Width="{Binding FillWidth}"
                                                HorizontalAlignment="Left" />
                                    </Border>
                                    <TextBlock Grid.Column="2"
                                               Text="{Binding ScoreText}"
                                               HorizontalAlignment="Right"
                                               FontSize="14" FontWeight="Bold"
                                               Foreground="{StaticResource TextSecondaryBrush}" />
                                </Grid>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </Grid>
            </Border>

            <!-- ── Diagnostics ── -->
            <Border Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="1" CornerRadius="16" Padding="28"
                    Visibility="{Binding IsDiagnosticsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <Border Style="{StaticResource InnerCardStyle}" Padding="20">
                        <StackPanel>
                            <TextBlock Text="SIM STATUS" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="{Binding DiagnosticsSimState}" Margin="0,12,0,0" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                            <TextBlock Text="LAST TELEMETRY" Margin="0,20,0,0" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="{Binding DiagnosticsLastTelemetry}" Margin="0,12,0,0" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                            <TextBlock Text="RECOVERY" Margin="0,20,0,0" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="{Binding DiagnosticsRecoveryState}" Margin="0,12,0,0" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                            <TextBlock Text="ACTIVE FLIGHT (from simcrewops.com)" Margin="0,20,0,0" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="{Binding DiagnosticsActiveFlight}" Margin="0,12,0,0" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                    <Border Grid.Column="2" Style="{StaticResource InnerCardStyle}" Padding="20">
                        <StackPanel>
                            <TextBlock Text="SYNC" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="{Binding DiagnosticsSyncState}" Margin="0,12,0,0" FontSize="15" FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}" TextWrapping="Wrap" />
                            <TextBlock Text="SETTINGS FILE" Margin="0,20,0,0" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="{Binding DiagnosticsSettingsPath}" Margin="0,12,0,0" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                            <TextBlock Text="STORAGE ROOT" Margin="0,20,0,0" Style="{StaticResource SectionLabelStyle}" />
                            <TextBlock Text="{Binding DiagnosticsStoragePath}" Margin="0,12,0,0" FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap" />
                        </StackPanel>
                    </Border>
                </Grid>
            </Border>

            <!-- ── Settings ── -->
            <Border Background="{StaticResource BgSurfaceBrush}"
                    BorderBrush="{StaticResource BorderDefaultBrush}"
                    BorderThickness="1" CornerRadius="16" Padding="28"
                    Visibility="{Binding IsSettingsVisible, Converter={StaticResource BooleanToVisibilityConverter}}">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*" />
                        <ColumnDefinition Width="20" />
                        <ColumnDefinition Width="*" />
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="API &amp; SYNC" Style="{StaticResource SectionLabelStyle}" />
                        <TextBlock Text="Base URL" Margin="0,14,0,6" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBox Text="{Binding SettingsEditor.BaseUrl, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Sim Sessions Path" Margin="0,12,0,6" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBox Text="{Binding SettingsEditor.SimSessionsPath, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Pilot API Token" Margin="0,12,0,6" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBox Text="{Binding SettingsEditor.PilotApiToken, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Tracker Version" Margin="0,12,0,6" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBox Text="{Binding SettingsEditor.TrackerVersion, UpdateSourceTrigger=PropertyChanged}" />
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="STORAGE" Style="{StaticResource SectionLabelStyle}" />
                        <TextBlock Text="Storage Root Directory" Margin="0,14,0,6" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBox Text="{Binding SettingsEditor.StorageRootDirectory, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Background Sync Interval (seconds)" Margin="0,12,0,6" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBox Text="{Binding SettingsEditor.BackgroundSyncIntervalSeconds, UpdateSourceTrigger=PropertyChanged}" />
                        <TextBlock Text="Max Sessions Per Pass" Margin="0,12,0,6" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource TextSecondaryBrush}" />
                        <TextBox Text="{Binding SettingsEditor.MaxSessionsPerPass, UpdateSourceTrigger=PropertyChanged}" />
                        <CheckBox Content="Enable background sync"
                                  IsChecked="{Binding SettingsEditor.BackgroundSyncEnabled}"
                                  Margin="0,16,0,0" />
                        <StackPanel Orientation="Horizontal" Margin="0,20,0,0">
                            <Button Content="Save Settings" Command="{Binding SaveSettingsCommand}" Style="{StaticResource PrimaryButtonStyle}" Margin="0,0,10,0" />
                            <Button Content="Retry Sync" Command="{Binding RetrySyncCommand}" Style="{StaticResource SecondaryButtonStyle}" />
                        </StackPanel>
                        <TextBlock Text="{Binding SettingsSaveStatus}"
                                   Margin="0,14,0,0" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}"
                                   TextWrapping="Wrap" />
                    </StackPanel>
                </Grid>
            </Border>

        </Grid>

        <!-- ═══════════════════════════════════════════════════════
             ROW 4 — NAV FOOTER
        ═══════════════════════════════════════════════════════ -->
        <Border Grid.Row="4"
                Background="{StaticResource BgSurfaceBrush}"
                BorderBrush="{StaticResource BorderDefaultBrush}"
                BorderThickness="1"
                CornerRadius="12">
            <Grid>
                <StackPanel Orientation="Horizontal" Margin="10,0" VerticalAlignment="Stretch">

                    <StackPanel Orientation="Vertical">
                        <Button Content="Dispatch" Command="{Binding ShowDashboardCommand}"
                                Style="{StaticResource NavButtonStyle}"
                                Height="42" />
                        <Border Height="2" CornerRadius="1" Background="{StaticResource AccentOrangeBrush}"
                                Visibility="{Binding DashboardNavUnderlineVisibility}"
                                Margin="10,0" />
                    </StackPanel>

                    <StackPanel Orientation="Vertical">
                        <Button Content="PIREP Draft" Command="{Binding ShowReviewCommand}"
                                Style="{StaticResource NavButtonStyle}" Height="42" />
                        <Border Height="2" CornerRadius="1" Background="{StaticResource AccentOrangeBrush}"
                                Visibility="{Binding ReviewNavUnderlineVisibility}"
                                Margin="10,0" />
                    </StackPanel>

                    <StackPanel Orientation="Vertical">
                        <Button Content="Diagnostics" Command="{Binding ShowDiagnosticsCommand}"
                                Style="{StaticResource NavButtonStyle}" Height="42" />
                        <Border Height="2" CornerRadius="1" Background="{StaticResource AccentOrangeBrush}"
                                Visibility="{Binding DiagnosticsNavUnderlineVisibility}"
                                Margin="10,0" />
                    </StackPanel>

                    <StackPanel Orientation="Vertical">
                        <Button Content="Settings" Command="{Binding ShowSettingsCommand}"
                                Style="{StaticResource NavButtonStyle}" Height="42" />
                        <Border Height="2" CornerRadius="1" Background="{StaticResource AccentOrangeBrush}"
                                Visibility="{Binding SettingsNavUnderlineVisibility}"
                                Margin="10,0" />
                    </StackPanel>
                </StackPanel>

                <!-- Version + Retry sync — right aligned -->
                <StackPanel Orientation="Horizontal"
                            HorizontalAlignment="Right"
                            VerticalAlignment="Center"
                            Margin="0,0,14,0">
                    <TextBlock Text="{x:Static vm:MainWindowViewModel.AppVersion}"
                               FontSize="10"
                               Foreground="{StaticResource TextSecondaryBrush}"
                               VerticalAlignment="Center"
                               Margin="0,0,12,0"
                               Opacity="0.6" />
                    <Button Content="↻ Retry Sync"
                            Command="{Binding RetrySyncCommand}"
                            Style="{StaticResource SecondaryButtonStyle}" />
                </StackPanel>
            </Grid>
        </Border>

    </Grid>
</Window>
