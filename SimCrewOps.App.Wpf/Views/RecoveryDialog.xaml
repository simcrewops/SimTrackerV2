<Window x:Class="SimCrewOps.App.Wpf.Views.RecoveryDialog"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Recover Session"
        Width="520"
        Height="300"
        ResizeMode="NoResize"
        WindowStartupLocation="CenterOwner"
        Background="#F6F8F2">
    <Grid Margin="24">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto" />
            <RowDefinition Height="*" />
            <RowDefinition Height="Auto" />
        </Grid.RowDefinitions>

        <TextBlock Text="Recover Previous Session"
                   FontSize="26"
                   FontWeight="Bold"
                   Foreground="#172B39" />

        <StackPanel Grid.Row="1" Margin="0,18,0,18">
            <TextBlock Text="{Binding SummaryText}"
                       TextWrapping="Wrap"
                       FontSize="15"
                       Foreground="#4E6066" />
            <Border Margin="0,18,0,0" Padding="16" Background="#FFFFFF" CornerRadius="16">
                <StackPanel>
                    <TextBlock Text="{Binding FlightText}" FontSize="16" FontWeight="SemiBold" Foreground="#172B39" />
                    <TextBlock Text="{Binding SavedText}" Margin="0,8,0,0" Foreground="#5F7076" />
                    <TextBlock Text="{Binding PendingText}" Margin="0,4,0,0" Foreground="#5F7076" />
                </StackPanel>
            </Border>
        </StackPanel>

        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right">
            <Button Content="Resume"
                    Width="110"
                    Height="38"
                    Margin="0,0,12,0"
                    Click="Resume_Click"
                    Style="{StaticResource ShellActionButtonStyle}" />
            <Button Content="Discard"
                    Width="110"
                    Height="38"
                    Margin="0,0,12,0"
                    Background="#FFE7E3"
                    BorderBrush="#D4625A"
                    Foreground="#B3473E"
                    Click="Discard_Click"
                    Style="{StaticResource ShellActionButtonStyle}" />
            <Button Content="Later"
                    Width="110"
                    Height="38"
                    Click="Later_Click"
                    Style="{StaticResource ShellActionButtonStyle}" />
        </StackPanel>
    </Grid>
</Window>
