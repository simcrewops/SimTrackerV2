<Application x:Class="SimCrewOps.App.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">
    <Application.Resources>

        <!-- ── Dark theme palette ─────────────────────────────────────── -->
        <!-- Base -->
        <SolidColorBrush x:Key="ShellBackgroundBrush"  Color="#0d1117" />
        <SolidColorBrush x:Key="ShellSurfaceBrush"     Color="#0d1117" />
        <SolidColorBrush x:Key="SidebarBrush"          Color="#0d1117" />
        <SolidColorBrush x:Key="TopBarBrush"           Color="#161b22" />
        <SolidColorBrush x:Key="HeaderBrush"           Color="#161b22" />
        <SolidColorBrush x:Key="PanelBrush"            Color="#161b22" />
        <SolidColorBrush x:Key="CardBrush"             Color="#1f2937" />
        <SolidColorBrush x:Key="HeroBrush"             Color="#161b22" />
        <SolidColorBrush x:Key="HeroCardBrush"         Color="#21262d" />

        <!-- Text -->
        <SolidColorBrush x:Key="TextPrimaryBrush"  Color="#e6edf3" />
        <SolidColorBrush x:Key="TextMutedBrush"    Color="#7d8590" />
        <SolidColorBrush x:Key="TextSubtleBrush"   Color="#484f58" />
        <SolidColorBrush x:Key="NavTextBrush"      Color="#c9d1d9" />

        <!-- Borders / dividers -->
        <SolidColorBrush x:Key="DividerBrush"      Color="#21262d" />
        <SolidColorBrush x:Key="BorderSubtleBrush" Color="#30363d" />

        <!-- Accent / state -->
        <SolidColorBrush x:Key="AccentBrush"       Color="#2563eb" />
        <SolidColorBrush x:Key="AccentSoftBrush"   Color="#58a6ff" />
        <SolidColorBrush x:Key="NavActiveBrush"    Color="#2563eb" />
        <SolidColorBrush x:Key="AmberBrush"        Color="#d29922" />
        <SolidColorBrush x:Key="DangerBrush"       Color="#f85149" />
        <SolidColorBrush x:Key="DangerSoftBrush"   Color="#3d1a19" />

        <!-- Instrument tile colours (kept teal for avionics feel) -->
        <SolidColorBrush x:Key="InstrumentTileBrush"  Color="#16303D" />
        <SolidColorBrush x:Key="InstrumentPanelBrush" Color="#0C1D25" />

        <!-- ── Converters ──────────────────────────────────────────────── -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />

        <!-- ── Nav item button style ──────────────────────────────────── -->
        <!-- Transparent click surface; inner Border handles the highlight -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background"       Value="Transparent" />
            <Setter Property="BorderThickness"  Value="0" />
            <Setter Property="Padding"          Value="0" />
            <Setter Property="Cursor"           Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <ContentPresenter />
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── Primary action button ──────────────────────────────────── -->
        <Style x:Key="ShellActionButtonStyle" TargetType="Button">
            <Setter Property="Foreground"      Value="#c9d1d9" />
            <Setter Property="Background"      Value="#21262d" />
            <Setter Property="BorderBrush"     Value="#30363d" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="14,6" />
            <Setter Property="Margin"          Value="0,0,10,0" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="6">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- ── TextBox (dark) ─────────────────────────────────────────── -->
        <Style TargetType="TextBox">
            <Setter Property="Background"      Value="#161b22" />
            <Setter Property="Foreground"      Value="#e6edf3" />
            <Setter Property="BorderBrush"     Value="#30363d" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"         Value="10,7" />
            <Setter Property="FontSize"        Value="13" />
            <Setter Property="CaretBrush"      Value="#e6edf3" />
        </Style>

        <!-- ── CheckBox (dark) ────────────────────────────────────────── -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="#c9d1d9" />
        </Style>

    </Application.Resources>
</Application>
