<Application x:Class="SimCrewOps.App.Wpf.App"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             xmlns:infra="clr-namespace:SimCrewOps.App.Wpf.Infrastructure">
    <Application.Resources>

        <!-- ═══════════════════════════════════════════
             SIMCREWOPS COLOR PALETTE
        ═══════════════════════════════════════════ -->

        <!-- Backgrounds -->
        <SolidColorBrush x:Key="BgBaseBrush"     Color="#0a0f1a" />
        <SolidColorBrush x:Key="BgSurfaceBrush"  Color="#141b2d" />
        <SolidColorBrush x:Key="BgElevatedBrush" Color="#1a1f2e" />
        <SolidColorBrush x:Key="BgMutedBrush"    Color="#1e2a3a" />

        <!-- Borders / Dividers -->
        <SolidColorBrush x:Key="BorderDefaultBrush" Color="#1e2a3a" />
        <SolidColorBrush x:Key="DividerBrush"        Color="#1e2a3a" />

        <!-- Text -->
        <SolidColorBrush x:Key="TextPrimaryBrush"   Color="#f0f2f5" />
        <SolidColorBrush x:Key="TextSecondaryBrush" Color="#8b95a5" />
        <SolidColorBrush x:Key="TextMutedBrush"     Color="#4a5568" />

        <!-- Accents -->
        <SolidColorBrush x:Key="AccentOrangeBrush" Color="#f48223" />
        <SolidColorBrush x:Key="AccentBlueBrush"   Color="#60a5fa" />
        <SolidColorBrush x:Key="AccentAmberBrush"  Color="#fbbf24" />
        <SolidColorBrush x:Key="AccentGreenBrush"  Color="#34d399" />
        <SolidColorBrush x:Key="AccentRedBrush"    Color="#f87171" />

        <!-- Alert card tinted backgrounds -->
        <SolidColorBrush x:Key="AlertAmberBgBrush"  Color="#17140a" />
        <SolidColorBrush x:Key="AlertAmberBorderBrush" Color="#4d3d0d" />
        <SolidColorBrush x:Key="AlertRedBgBrush"    Color="#170a0a" />
        <SolidColorBrush x:Key="AlertRedBorderBrush"   Color="#4d1010" />
        <SolidColorBrush x:Key="AlertGreenBgBrush"  Color="#0a170f" />
        <SolidColorBrush x:Key="AlertGreenBorderBrush" Color="#0d4d26" />

        <!-- Light indicator tints -->
        <SolidColorBrush x:Key="LightRedBgBrush"   Color="#1a0d0d" />
        <SolidColorBrush x:Key="LightWhiteBgBrush" Color="#141b28" />
        <SolidColorBrush x:Key="LightAmberBgBrush" Color="#1a150a" />

        <!-- Converters -->
        <BooleanToVisibilityConverter x:Key="BooleanToVisibilityConverter" />
        <infra:InverseBooleanConverter x:Key="InverseBooleanConverter" />

        <!-- ═══════════════════════════════════════════
             GLOBAL STYLES
        ═══════════════════════════════════════════ -->

        <!-- Primary button (orange) -->
        <Style x:Key="PrimaryButtonStyle" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource AccentOrangeBrush}" />
            <Setter Property="Foreground"   Value="White" />
            <Setter Property="BorderBrush"  Value="{StaticResource AccentOrangeBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"      Value="14,7" />
            <Setter Property="FontWeight"   Value="SemiBold" />
            <Setter Property="FontSize"     Value="12" />
            <Setter Property="Cursor"       Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Secondary button (ghost dark) -->
        <Style x:Key="SecondaryButtonStyle" TargetType="Button">
            <Setter Property="Background"   Value="{StaticResource BgElevatedBrush}" />
            <Setter Property="Foreground"   Value="{StaticResource TextSecondaryBrush}" />
            <Setter Property="BorderBrush"  Value="{StaticResource BorderDefaultBrush}" />
            <Setter Property="BorderThickness" Value="1" />
            <Setter Property="Padding"      Value="14,7" />
            <Setter Property="FontWeight"   Value="SemiBold" />
            <Setter Property="FontSize"     Value="12" />
            <Setter Property="Cursor"       Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Nav button (transparent, bottom bar) -->
        <Style x:Key="NavButtonStyle" TargetType="Button">
            <Setter Property="Background"      Value="Transparent" />
            <Setter Property="Foreground"      Value="{StaticResource TextMutedBrush}" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Padding"         Value="10,0" />
            <Setter Property="FontWeight"      Value="SemiBold" />
            <Setter Property="FontSize"        Value="12" />
            <Setter Property="Cursor"          Value="Hand" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border Background="Transparent">
                            <ContentPresenter HorizontalAlignment="Center"
                                              VerticalAlignment="Center"
                                              Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- Section label (10pt, uppercase, muted) -->
        <Style x:Key="SectionLabelStyle" TargetType="TextBlock">
            <Setter Property="Foreground"       Value="{StaticResource TextMutedBrush}" />
            <Setter Property="FontSize"         Value="10" />
            <Setter Property="FontWeight"       Value="Bold" />
        </Style>

        <!-- Monospace value (OOOI times, paths) -->
        <Style x:Key="MonoValueStyle" TargetType="TextBlock">
            <Setter Property="FontFamily" Value="Consolas" />
            <Setter Property="FontSize"   Value="14" />
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
        </Style>

        <!-- Standard card border -->
        <Style x:Key="CardStyle" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource BgSurfaceBrush}" />
            <Setter Property="BorderBrush"      Value="{StaticResource BorderDefaultBrush}" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="CornerRadius"     Value="14" />
        </Style>

        <!-- Elevated inner card -->
        <Style x:Key="InnerCardStyle" TargetType="Border">
            <Setter Property="Background"       Value="{StaticResource BgElevatedBrush}" />
            <Setter Property="BorderBrush"      Value="{StaticResource BorderDefaultBrush}" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="CornerRadius"     Value="10" />
        </Style>

        <!-- TextBox dark style -->
        <Style TargetType="TextBox">
            <Setter Property="Background"       Value="{StaticResource BgElevatedBrush}" />
            <Setter Property="Foreground"       Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="BorderBrush"      Value="{StaticResource BorderDefaultBrush}" />
            <Setter Property="BorderThickness"  Value="1" />
            <Setter Property="Padding"          Value="12,8" />
            <Setter Property="FontSize"         Value="13" />
            <Setter Property="CaretBrush"       Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="TextBox">
                        <Border Background="{TemplateBinding Background}"
                                BorderBrush="{TemplateBinding BorderBrush}"
                                BorderThickness="{TemplateBinding BorderThickness}"
                                CornerRadius="8">
                            <ScrollViewer x:Name="PART_ContentHost"
                                          Margin="{TemplateBinding Padding}" />
                        </Border>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <!-- CheckBox dark style -->
        <Style TargetType="CheckBox">
            <Setter Property="Foreground" Value="{StaticResource TextPrimaryBrush}" />
            <Setter Property="FontSize"   Value="13" />
        </Style>

    </Application.Resources>
</Application>
